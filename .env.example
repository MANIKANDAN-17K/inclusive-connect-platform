# ─────────────────────────────────────────────────────────────────────
#  InclusiveConnect — Environment Variables Template
#
#  1. Copy this file:  cp .env.example .env
#  2. Fill in every value below
#  3. NEVER commit .env to source control (already in .gitignore)
# ─────────────────────────────────────────────────────────────────────

# ── MySQL Database ───────────────────────────────────────────────────
# Root password for the MySQL container (used only on first boot)
MYSQL_ROOT_PASSWORD=change_me_root_password

# Application database name
MYSQL_DATABASE=inclusive_connect

# Application DB user (used by the backend)
MYSQL_USER=ic_user
MYSQL_PASSWORD=change_me_db_password

# Host and port as seen by the Spring Boot backend container
# When using Docker Compose, DB_HOST should be the service name: "mysql"
DB_HOST=mysql
DB_PORT=3306
DB_NAME=inclusive_connect
DB_USERNAME=ic_user
DB_PASSWORD=change_me_db_password
DB_USE_SSL=false

# ── JWT ──────────────────────────────────────────────────────────────
# Must be a long (≥256-bit), random Base64 string.
# Generate one: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_BASE64_SECRET_AT_LEAST_64_CHARS

# Token expiry in milliseconds (defaults shown)
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# ── Mail (SMTP) ──────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# For Gmail: generate an App Password — not your account password
MAIL_PASSWORD=your_app_password

# ── Cloudinary (file/image storage) ─────────────────────────────────
# Full URL format:  cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost,https://your-domain.com

# ── Server ───────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Docker image tags (used in docker-compose.yml) ───────────────────
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest
